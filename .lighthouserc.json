{
  "ci": {
    "collect": {
      "numberOfRuns": 1,
      "startServerCommand": "python3 -m http.server 4173 --directory .",
      "startServerReadyPattern": "Serving HTTP on",
      "url": [
        "http://127.0.0.1:4173/"
      ],
      "settings": {
        "preset": "desktop",
        "chromeFlags": "--headless --no-sandbox --disable-gpu"
      }
    },
    "assert": {
      "assertions": {
        "categories:performance": [
          "warn",
          {
            "minScore": 0.6
          }
        ],
        "categories:accessibility": [
          "error",
          {
            "minScore": 0.9
          }
        ],
        "categories:best-practices": [
          "warn",
          {
            "minScore": 0.9
          }
        ],
        "categories:seo": [
          "error",
          {
            "minScore": 0.9
          }
        ]
      }
    },
    "upload": {
      "target": "filesystem",
      "outputDir": "./.lighthouseci"
    }
  }
}
